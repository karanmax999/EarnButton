# ─── Testnet mode ────────────────────────────────────────────────────────────
# Set to "true" to use Base Sepolia testnet, "false" (or omit) for mainnet
NEXT_PUBLIC_USE_TESTNET=true

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Alchemy/Infura alternatives:
# NEXT_PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ─── Vault address ────────────────────────────────────────────────────────────
# YO Protocol vault address (testnet or mainnet depending on NEXT_PUBLIC_USE_TESTNET)
NEXT_PUBLIC_YO_VAULT_ADDRESS=
NEXT_PUBLIC_VAULT_ADDRESS=

# ─── WalletConnect ────────────────────────────────────────────────────────────
# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
